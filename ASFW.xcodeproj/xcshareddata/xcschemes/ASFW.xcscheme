<?xml version="1.0" encoding="UTF-8"?>
<Scheme
   LastUpgradeVersion = "2610"
   version = "1.7">
   <BuildAction
      parallelizeBuildables = "YES"
      buildImplicitDependencies = "YES"
      buildArchitectures = "Automatic">
      <PostActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Re-sign dext with Apple Development cert"
               scriptText = "#!/bin/bash&#10;set -euo pipefail&#10;# ORDER MATTERS:&#10;# 1. Sign ASFW.app first (while dext still has ad-hoc, no DriverKit entitlements&#10;#    in the nested bundle that could block codesign).&#10;# 2. Sign dext second (breaks outer app seal, but systemextensionsctl developer on&#10;#    relaxes bundle validation; the dext's own signature is what counts for loading).&#10;# Result: both teamID=4MJNRC8SW5, satisfying systemextensionsctl's team-match check.&#10;&#10;IDENTITY=&quot;Apple Development: j.slipiec@gmail.com (239NB3LFDQ)&quot;&#10;# Skip re-signing when the developer identity is not in the keychain (e.g. CI runner).&#10;if ! security find-identity -v -p codesigning 2&gt;/dev/null | grep -qF &quot;${IDENTITY}&quot;; then&#10;    echo &quot;Re-sign skipped: identity not in keychain.&quot;; exit 0&#10;fi&#10;DEXT_ENTITLEMENTS=&quot;${SRCROOT}/ASFWDriver/ASFWDriver.entitlements&quot;&#10;APP_ENTITLEMENTS=&quot;${SRCROOT}/ASFW/App.entitlements&quot;&#10;DEXT_NAME=&quot;net.mrmidi.ASFW.ASFWDriver.dext&quot;&#10;APP=&quot;${BUILT_PRODUCTS_DIR}/ASFW.app&quot;&#10;EMBEDDED=&quot;${APP}/Contents/Library/SystemExtensions/${DEXT_NAME}&quot;&#10;&#10;if [ ! -d &quot;${EMBEDDED}&quot; ]; then&#10;    echo &quot;ERROR: dext not found: ${EMBEDDED}&quot;; exit 1&#10;fi&#10;&#10;# Strip iCloud/Finder extended attributes that codesign rejects (app + embedded dext).&#10;xattr -cr &quot;${APP}&quot;&#10;xattr -cr &quot;${EMBEDDED}&quot;&#10;&#10;# Step 1: Re-sign app (dext inside is still ad-hoc — no DriverKit entitlement conflict).&#10;codesign --force --options runtime --sign &quot;${IDENTITY}&quot; --entitlements &quot;${APP_ENTITLEMENTS}&quot; --timestamp=none &quot;${APP}&quot;&#10;echo &quot;App signed: $(codesign -dvvv &quot;${APP}&quot; 2&gt;&amp;1 | grep TeamIdentifier)&quot;&#10;&#10;# Step 2: Re-sign dext with full DriverKit entitlements.&#10;# This invalidates the outer app seal — acceptable with systemextensionsctl developer on.&#10;codesign --force --sign &quot;${IDENTITY}&quot; --entitlements &quot;${DEXT_ENTITLEMENTS}&quot; --timestamp=none &quot;${EMBEDDED}&quot;&#10;echo &quot;Dext signed: $(codesign -dvvv &quot;${EMBEDDED}&quot; 2&gt;&amp;1 | grep TeamIdentifier)&quot;&#10;">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "3A1693D72E808727000BD368"
                     BuildableName = "ASFW.app"
                     BlueprintName = "ASFW"
                     ReferencedContainer = "container:ASFW.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PostActions>
      <BuildActionEntries>
         <BuildActionEntry
            buildForTesting = "YES"
            buildForRunning = "YES"
            buildForProfiling = "YES"
            buildForArchiving = "YES"
            buildForAnalyzing = "YES">
            <BuildableReference
               BuildableIdentifier = "primary"
