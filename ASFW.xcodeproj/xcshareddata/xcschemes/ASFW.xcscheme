               BuildableName = "ASFW.app"
               BlueprintName = "ASFW"
               ReferencedContainer = "container:ASFW.xcodeproj">
            </BuildableReference>
         </BuildActionEntry>
      </BuildActionEntries>
   </BuildAction>
